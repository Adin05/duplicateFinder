{
  "name": "duplicate-finder-studio",
  "version": "1.0.0",
  "author": "Personal Project",
  "description": "Windows duplicate finder CLI and Electron desktop app",
  "main": "electron/main.js",
  "scripts": {
    "cli": "node app.js",
    "dist": "electron-builder --win nsis",
    "generate:icons": "node scripts/generate-icons.js",
    "pack": "electron-builder --dir",
    "start": "electron ."
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.personalproject.duplicatefinder",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "productName": "Duplicate Finder Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "app.js",
      "collector.js",
      "engine.js",
      "hasher.js",
      "mover.js",
      "scanner.js",
      "utils.js",
      "electron/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "allowToChangeInstallationDirectory": true,
      "installerHeaderIcon": "build/icon.ico",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "oneClick": false,
      "perMachine": false
    }
  }
}
